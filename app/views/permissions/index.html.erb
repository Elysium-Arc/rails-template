<div class="mx-auto px-4 py-8">
  <% content_for :page_title, t('permissions.index.title') %>
  <%= render DataTableComponent.new(
    title: t('permissions.index.title'),
    table_frame_id: 'permissions-table',
    filters: @filters,
    active_filter_keys: @active_filter_keys,
    columns: [
      {
        key: :name,
        label: t('permissions.columns.name'),
        sortable: true,
        priority: :high,
        truncate: false
      },
      {
        key: :description,
        label: t('permissions.columns.description'),
        sortable: false,
        priority: :high,
        truncate: true
      },
      {
        key: :roles_count,
        label: t('permissions.columns.roles'),
        sortable: false,
        priority: :normal,
        format: ->(permission) { permission.roles.count }
      },
      {
        key: :created_at,
        label: t('permissions.columns.created_at'),
        type: :datetime,
        sortable: true,
        priority: :low
      }
    ],
    data: @permissions,
    pagy: @pagy,
    sort_column: params[:sort],
    sort_direction: params[:direction],
    current_filters: params.slice(:q, :name_cont, :description_cont, :resource_type_cont, :created_at_gteq, :created_at_lteq, :updated_at_gteq, :updated_at_lteq).to_h,
    empty_message: t('permissions.index.empty_message', default: 'No permissions found. Create your first permission to get started.'),
    selectable: true,
    selected_ids: params[:selected_ids] || [],
    dom_id: ->(permission) { dom_id(permission) },
    record_id: ->(permission) { permission.hashid },
    row_actions: [
      {
        label: t('common.actions.view'),
        icon: "eye",
        url: ->(permission) { permission_path(id: permission.id) },
        type: :link,
        data: {
          turbo_frame: "modal-content",
          modal_title_param: t('permissions.show.title', default: 'Permission Details'),
          modal_size: "md"
        }
      },
      {
        label: t('common.actions.edit'),
        icon: "pencil",
        url: ->(permission) { edit_permission_path(id: permission.id) },
        type: :link,
        data: {
          turbo_frame: "modal-content",
          modal_title_param: t('permissions.edit.title', default: 'Edit Permission'),
          modal_size: "md",
          turbo_prefetch: true
        }
      },
      {
        label: t('common.actions.delete'),
        icon: "trash-2",
        url: ->(permission) { permission_path(id: permission.id) },
        type: :button,
        method: :delete,
        data: { turbo_confirm: t('permissions.messages.confirm_delete', default: 'Are you sure you want to delete this permission?') }
      }
    ],
    action_buttons: [
      {
        label: t('permissions.new.title', default: 'New Permission'),
        icon: "plus",
        url: new_permission_path,
        type: :link,
        variant: "primary",
        data: {
          turbo_frame: "modal-content",
          modal_title_param: t('permissions.new.title', default: 'New Permission'),
          modal_size: "md"
        }
      }
    ]
  ) %>
</div>
