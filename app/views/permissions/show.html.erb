<%= turbo_frame_tag "modal-content" do %>
  <div class="space-y-6">
    <div>
      <h3 class="text-lg font-medium"><%= t('permissions.show.name') %></h3>
      <p class="mt-1 text-sm text-gray-600"><%= @permission.name %></p>
    </div>

    <div>
      <h3 class="text-lg font-medium"><%= t('permissions.show.description') %></h3>
      <p class="mt-1 text-sm text-gray-600"><%= @permission.description %></p>
    </div>

    <div>
      <h3 class="text-lg font-medium"><%= t('permissions.show.roles') %></h3>
      <% if @permission.roles.any? %>
        <ul class="mt-2 space-y-1">
          <% @permission.roles.order(:name).each do |role| %>
            <li class="text-sm text-gray-600">
              <span class="font-medium"><%= role.name %></span>
              <% if role.description.present? %>
                - <%= role.description %>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="mt-1 text-sm text-gray-600"><%= t('permissions.show.no_roles', default: 'Not assigned to any roles') %></p>
      <% end %>
    </div>

    <div class="border-t pt-4">
      <dl class="grid grid-cols-2 gap-4 text-sm">
        <div>
          <dt class="font-medium text-gray-500"><%= t('permissions.show.created_at') %></dt>
          <dd class="mt-1"><%= l(@permission.created_at, format: :long) %></dd>
        </div>
        <div>
          <dt class="font-medium text-gray-500"><%= t('permissions.show.updated_at') %></dt>
          <dd class="mt-1"><%= l(@permission.updated_at, format: :long) %></dd>
        </div>
      </dl>
    </div>
  </div>
<% end %>
