<%= turbo_frame_tag 'roles-table' do %>
  <%= render TableComponent.new(
    columns: [
      { 
        key: :name, 
        label: t('roles.columns.name'), 
        sortable: true,
        priority: :high,
        truncate: false
      },
      {
        key: :description,
        label: t('roles.columns.description'),
        sortable: false,
        priority: :normal,
        truncate: true
      },
      {
        key: :permissions_count,
        label: t('roles.columns.permissions'),
        sortable: false,
        priority: :normal,
        format: ->(role) { role.permissions.count }
      },
      {
        key: :users_count,
        label: t('roles.columns.users'),
        sortable: false,
        priority: :normal,
        format: ->(role) { role.users.count }
      },
      {
        key: :created_at,
        label: t('roles.columns.created_at'),
        type: :datetime,
        sortable: true,
        priority: :low
      }
    ],
    data: roles,
    pagy: pagy,
    sort_column: custom_params["sort"],
    sort_direction: custom_params["direction"],
    empty_message: t('roles.index.empty_message', default: 'No roles found. Create your first role to get started.'),
    selectable: true,
    selected_ids: custom_params["selected_ids"] || [],
    dom_id: ->(role) { dom_id(role) },
    record_id: ->(role) { role.hashid },
    row_actions: [
      {
        label: t('common.actions.view'),
        icon: "eye",
        url: ->(role) { role_path(role: role.id) },
        type: :link,
        data: { 
          turbo_frame: "modal-content",
          modal_title_param: t('roles.show.title', default: 'Role Details'),
          modal_size: "lg"
        }
      },
      {
        label: t('common.actions.edit'),
        icon: "pencil",
        url: ->(role) { edit_role_path(id: role.id) },
        type: :link,
        data: { 
          turbo_frame: "modal-content",
          modal_title_param: t('roles.edit.title', default: 'Edit Role'),
          modal_size: "lg"
        }
      },
      {
        label: t('common.actions.delete'),
        icon: "trash-2",
        url: ->(role) { role_path(role: role.id) },
        type: :button,
        method: :delete,
        data: { turbo_confirm: t('roles.messages.confirm_delete', default: 'Are you sure you want to delete this role?') }
      }
    ]
  ) %>
  <% if pagy %>
    <%= render PagyComponent.new(
      pagy: pagy,
      form_id: "filter-form"
    ) %>
  <% end %>
<% end %>
